# ─────────────────────────────────────────────────────────────────────────────
# AZ Digital — Variables d'environnement requises
# ─────────────────────────────────────────────────────────────────────────────
#
# INSTRUCTIONS :
#  1. Copier ce fichier en .env  →  cp .env.example .env
#  2. Ne JAMAIS commiter le fichier .env (il est dans .gitignore)
#  3. Sur Netlify : Site configuration → Environment variables → Add variable
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Resend ───────────────────────────────────────────────────────────────────
#
# Clé API Resend (commence par "re_")
# Obtenir sur : https://resend.com/api-keys
#
RESEND_API_KEY=re_VOTRE_CLE_API_ICI

# ── Adresses email ───────────────────────────────────────────────────────────
#
# EMAIL_TO : adresse(s) qui recevront les notifications
# Pour plusieurs destinataires, séparer par une virgule
#
EMAIL_TO=toi@email.com,collegue@email.com

# EMAIL_FROM : l'adresse expéditrice affichée dans les emails reçus
# Format requis : "Nom <adresse@domaine.com>"
# IMPORTANT : le domaine doit être vérifié dans Resend, OU utiliser
#             onboarding@resend.dev pour tester sans vérification de domaine.
#
EMAIL_FROM=AZ Digital <notifications@azdigital.ca>
